# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Database Configuration
# Leave empty for SQLite (development)
# Set DATABASE_URL to use PostgreSQL (production)
# DATABASE_URL=postgresql://username:password@host:port/dbname?sslmode=require

# Supabase Configuration (Optional - for REST API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Example Supabase PostgreSQL URL:
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require&connect_timeout=10
